{
    "context_stores": [
        {
            "name": "vs_IT_learning",
            "actor": {
                "type": "qwshen.document.store.chroma.ChromaVS",
                "kwargs": {
                    "embeddings": {
                        "type": "langchain_ollama.OllamaEmbeddings",
                        "kwargs": {
                            "model":"${LLM_EMBEDDINGS_MODEL}",
                            "base_url": "${LLM_INFERENCE}"
                        }
                    },
                    "store_file": "/opt/agentic-rag-1.0.0/db/chroma/it_learning"
                }
            }
        }
    ],    
    "service_def": {
        "prompts": [
            {
                "name": "p_chat",
                "actor": {
                    "type": "qwshen.common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${PROMPTS_DIRECTORY}/chat_with_history_prompt.yaml"
                    }
                }                
            },
            {
                "name": "p_document_grading",
                "actor":{
                    "type": "qwshen.common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${PROMPTS_DIRECTORY}/document_grading_prompt.yaml"
                    }
                }
            },
            {
                "name": "p_query_refining",
                "actor":{
                    "type": "qwshen.common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${PROMPTS_DIRECTORY}/query_refining_prompt.yaml"
                    }
                }
            },
            {
                "name": "p_answer_grounding",
                "actor":{
                    "type": "qwshen.common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${PROMPTS_DIRECTORY}/answer_grounding_prompt.yaml"
                    }
                }
            },
            {
                "name": "p_answer_rewriting",
                "actor":{
                    "type": "qwshen.common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${PROMPTS_DIRECTORY}/answer_rewriting_prompt.yaml"
                    }
                }
            }
        ],
        "chat_models": [
            {
                "name": "m_writing",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "model_key": "model",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "${LLM_CHAT_MODEL}",
                        "temperature": 0.35
                    }
                }
            },
            {
                "name": "m_reasoning",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "${LLM_REASONING_MODEL}"
                    }
                }
            },
            {
                "name": "m_agency",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "${LLM_AGENT_MODEL}"
                    }
                }
            }
        ],
        "retrievals": [
            {
                "name": "r_chat",
                "description": "IT learning support documents",
                "search": {
                    "type": "similarity",
                    "kwargs": {
                        "k": 6,
                        "fetch_k": 16,
                        "score_threshold": 0.3,
                        "lambda_mult": 0.8
                    },
                    "document_store": "vs_IT_learning"
                }
            }
        ],
        "services":[
            {
                "name": "IT_learning_chat",
                "definition": {
                    "prompt": {
                        "ref": "p_chat",
                        "with_history": {
                            "use_summary": false,
                            "window_k": 5
                        }
                    },
                    "context": {
                        "ref_retrievals": ["r_chat"],
                        "agent": {
                            "ref_model": "m_agency"
                        }
                    },
                    "generation": {
                        "ref_model": "m_writing",
                        "answer_rewriting": {
                            "ref_prompt": "p_answer_rewriting",
                            "ref_model": "m_writing"
                        }
                    },
                    "agentivity": {
                        "query_refining": {
                            "ref_prompt": "p_query_refining",
                            "ref_model": "m_writing"
                        },
                        "document_grading": {
                            "ref_prompt": "p_document_grading",
                            "ref_model": "m_reasoning",
                            "accept_gradedness_answers": ["relevant", "yes"],
                            "reject_gradedness_answers": ["irrelevant", "no"],
                            "min_threshold_score": 0.6,
                            "max_iterations": 2
                        },
                        "answer_grounding": {
                            "ref_prompt": "p_answer_grounding",
                            "ref_model": "m_reasoning",
                            "accept_groundedness_answers": ["yes"],
                            "reject_groundedness_answers": ["no"],
                             "min_threshold_score": 0.6,
                            "max_iterations": 3
                        }
                    }                    
                }
            }
        ]
    },
    "logging": {
        "directory": "${LOGGING_DIRECTORY}",
        "level": "debug"
    }
}

