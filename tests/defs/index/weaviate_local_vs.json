{
    "context_stores": [
        {
            "name": "rag_customers",
            "actor": {
                "type": "qwshen.document.store.weaviate.WeaviateVS",
                "kwargs": {
                    "embeddings": {
                        "type": "langchain_ollama.OllamaEmbeddings",
                        "kwargs": {
                            "model":"${LLM_EMBEDDINGS_MODEL}",
                            "base_url": "${LLM_INFERENCE}"
                        }
                    },
                    "client": {
                        "mode": "local",
                        "options": {
                            "host": "localhost",
                            "port": 8080,
                            "grpc_port": 50051
                        }
                    },
                    "index_name": "customers"
                }
            }
        }
    ],
    "indexing_def": [
        {
            "name": "customers_indexing",
            "loading": {
                "actors": [
                    {
                        "actor": {
                            "type": "qwshen.document.loading.file.FileLoader",
                            "kwargs": {
                                "directory": "${DOCUMENTS_DIRECTORY}/pdf",
                                "file_extensions": ".pdf",
                                "worker": {
                                    "type": "langchain_community.document_loaders.pdf.PyPDFLoader",
                                    "kwargs": {
                                        "extract_images": false
                                    }
                                }
                            }
                        }
                    }
                ]
            },
            "splitting": {
                "actors": [
                    {
                        "type": "qwshen.document.splitting.text.TextSplitter",
                        "kwargs": {
                            "worker": {
                                "type": "langchain_text_splitters.character.RecursiveCharacterTextSplitter",
                                "kwargs": { 
                                    "chunk_size": 1600,
                                    "chunk_overlap": 640
                                }
                            }
                        }
                    }
                ],
                "chunk_size_threshold": 1024,
                "chunk_size_strategy": "append"
            },
            "indexing": {
                "concurrency": {
                    "workers": 1
                },
                "document_store": "rag_customers",
                "document_size_threshold": 320
            }
        }
    ]    
}