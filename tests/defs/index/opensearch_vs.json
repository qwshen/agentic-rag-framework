{
    "context_stores": [
        {
            "name": "rag_dev",
            "actor": {
                "type": "qwshen.document.store.opensearch.OpenSearchVS",
                "kwargs": {
                    "embedding_function": {
                        "type": "langchain_ollama.OllamaEmbeddings",
                        "kwargs": {
                            "model":"${LLM_EMBEDDINGS_MODEL}",
                            "base_url": "${LLM_INFERENCE}"
                        }
                    },
                    "engine": "faiss",
                    "opensearch_url": "http://localhost:9200",
                    "index_name": "tickets"
                }
            }
        }
    ],
    "indexing_def": [
        {
            "name": "dev_indexing",
            "loading": {
                "actors": [
                    {
                        "actor": {
                            "type": "qwshen.document.loading.file.FileLoader",
                            "kwargs": {
                                "directory": "${DOCUMENTS_DIRECTORY}/pdf",
                                "file_extensions": ".pdf",
                                "worker": {
                                    "type": "langchain_community.document_loaders.pdf.PyPDFLoader",
                                    "kwargs": {
                                        "extract_images": false
                                    }
                                }
                            }
                        }
                    }
                ]
            },
            "splitting": {
                "actors": [
                    {
                        "type": "qwshen.document.splitting.text.TextSplitter",
                        "kwargs": {
                            "worker": {
                                "type": "langchain_text_splitters.character.RecursiveCharacterTextSplitter",
                                "kwargs": { 
                                    "chunk_size": 1600,
                                    "chunk_overlap": 640
                                }
                            }
                        }
                    }
                ],
                "chunk_size_threshold": 320,
                "chunk_size_strategy": "discard"                    
            },
            "indexing": {
                "concurrency": {
                    "workers": 1
                },
                "document_store": "rag_dev",
                "document_size_threshold": 240
            }
        }
    ]    
}