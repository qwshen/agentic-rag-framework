{
    "context_stores": [
        {
            "name": "vs_pg_vector_customers",
            "actor": {
                "type": "document.store.pgvector.PgVectorVS",
                "kwargs": {
                    "embeddings": {
                        "type": "langchain_ollama.OllamaEmbeddings",
                        "kwargs": {
                            "model":"${LLM_EMBEDDINGS_MODEL}",
                            "base_url": "${LLM_INFERENCE}"
                        }
                    },
                    "connection": "postgresql+psycopg://langchain:langchain@localhost:6024/langchain",
                    "collection_name": "customers"
                }
            }
        }
    ],    
    "service_def": {
        "prompts": [
            {
                "name": "chat_prompt",
                "actor": {
                    "type": "common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${CHAT_PROMPT_FILE}"
                    }
                }                
            },
            {
                "name": "document_grading_prompt",
                "actor":{
                    "type": "common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${DOCUMENT_GRADING_PROMPT_FILE}"
                    }
                }
            },
            {
                "name": "query_refinement_prompt",
                "actor":{
                    "type": "common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${QUERY_REWRITE_PROMPT_FILE}"
                    }
                }
            },
            {
                "name": "answer_grounding_prompt",
                "actor":{
                    "type": "common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${ANSWER_GROUNDING_PROMPT_FILE}"
                    }
                }
            },
            {
                "name": "answer_rewriting_prompt",
                "actor":{
                    "type": "common.prompt.load_from_file",
                    "kwargs": {
                        "path": "${ANSWER_REWRITE_PROMPT_FILE}"
                    }
                }
            }
        ],
        "chat_models": [
            {
                "name": "llama3.2",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "model_key": "model",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "llama3.2",
                        "temperature": 0.35
                    }
                }
            },
            {
                "name": "deepseek-r1:1.5b",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "deepseek-r1:1.5b"
                    }
                }
            },
            {
                "name": "mistral:7b",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "mistral:7b",
                        "temperature": 0.0
                    }
                }
            },
            {
                "name": "gpt-oss:20b",
                "actor": {
                    "type": "langchain_ollama.ChatOllama",
                    "kwargs": {
                        "base_url": "${LLM_INFERENCE}",
                        "model": "gpt-oss:20b",
                        "temperature": 0.2
                    }
                }
            }
        ],
        "retrievals": [
            {
                "name": "r_customers",
                "description": "Customer support documents",
                "search": {
                    "type": "similarity",
                    "kwargs": {
                        "k": 6,
                        "fetch_k": 16,
                        "score_threshold": 0.8,
                        "filter": {
                            "paper_title": "GPT-4 Technical Report"
                        },
                        "lambda_mult": 0.3
                    },
                    "document_store": "vs_pg_vector_customers"
                }
            }
        ],
        "services":[
            {
                "name": "customer_support_chat",
                "definition": {
                    "prompt": {
                        "ref": "chat_prompt",
                        "with_history": {
                            "use_summary": false,
                            "window_k": 5
                        }
                    },
                    "context": {
                        "ref_retrievals": ["r_customers"],
                        "agent": {
                            "ref_model": "llama3.2"
                        }
                    },
                    "generation": {
                        "ref_model": "deepseek-r1:1.5b",
                        "answer_rewriting": {
                            "ref_prompt": "answer_rewriting_prompt",
                            "ref_model": "llama3.2"
                        }
                    },
                    "agentivity": {
                        "query_refinement": {
                            "ref_prompt": "query_refinement_prompt",
                            "ref_model": "llama3.2"
                        },
                        "document_grading": {
                            "ref_prompt": "document_grading_prompt",
                            "ref_model": "deepseek-r1:1.5b",
                            "accept_gradedness_answers": ["relevant", "yes"],
                            "min_threshold_score": 0.6,
                            "max_iterations": 2
                        },
                        "answer_grounding": {
                            "ref_prompt": "answer_grounding_prompt",
                            "ref_model": "deepseek-r1:1.5b",
                            "accept_groundedness_answers": ["yes"],
                            "max_iterations": 3
                        }
                    }
                },
                "access_roles": [
                    "marketing_sales", "system_admins"
                ]
            }
        ]
    },
    "logging": {
        "directory": "${LOGS_DIRECTORY}",
        "level": "debug"
    }
}

